# Required
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=your_bot_username

# Logging
LOG_LEVEL=INFO
POLLING_RESTART_DELAY_SECONDS=8

# Backend load control
AI_CONCURRENCY_LIMIT=24
IMAGE_CONCURRENCY_LIMIT=8
DOWNLOAD_CONCURRENCY_LIMIT=6
CONVERTER_CONCURRENCY_LIMIT=4
API_CONCURRENCY_LIMIT=16
AI_QUEUE_WAIT_TIMEOUT_SECONDS=20
IMAGE_QUEUE_WAIT_TIMEOUT_SECONDS=25
DOWNLOAD_QUEUE_WAIT_TIMEOUT_SECONDS=30
CONVERTER_QUEUE_WAIT_TIMEOUT_SECONDS=30
API_QUEUE_WAIT_TIMEOUT_SECONDS=15
AI_EXECUTION_TIMEOUT_SECONDS=120
IMAGE_EXECUTION_TIMEOUT_SECONDS=90
DOWNLOAD_EXECUTION_TIMEOUT_SECONDS=0
CONVERTER_EXECUTION_TIMEOUT_SECONDS=0
API_EXECUTION_TIMEOUT_SECONDS=30

# Telegram free cloud limits (for /limits info)
TELEGRAM_FREE_UPLOAD_LIMIT_MB=50
TELEGRAM_FREE_DOWNLOAD_LIMIT_MB=20

# 1secmail
ONESECMAIL_API_BASE=https://www.1secmail.com/api/v1/
MAILTM_API_BASE=https://api.mail.tm

# TinyURL (official API token, optional; if empty legacy free endpoint ishlatiladi)
TINYURL_API_TOKEN=your_tinyurl_api_token
TINYURL_DOMAIN=tinyurl.com

# RapidAPI (optional; bo'sh bo'lsa fallback servislar ishlaydi)
RAPIDAPI_KEY=your_rapidapi_key

# AI / OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_HTTP_REFERER=https://github.com/ArabboyWeb/xizmatlarebot
OPENROUTER_X_TITLE=Xizmatlar E-Bot AI
AI_SYSTEM_PROMPT=

# AI free plan
AI_FREE_MODEL_SIMPLE=z-ai/glm-4.5-air:free
AI_FREE_MODEL_COMPLEX=qwen/qwen3-vl-235b-a22b-thinking
AI_FREE_CHAT_DAILY_LIMIT=10
AI_FREE_CHAT_COOLDOWN_SECONDS=600
AI_FREE_IMAGE_DAILY_LIMIT=5
AI_FREE_IMAGE_COOLDOWN_SECONDS=1800
AI_FREE_RPM=12

# AI premium plan
AI_PREMIUM_CHAT_MODEL=x-ai/grok-4.1-fast
AI_PREMIUM_MODEL_COMPLEX=x-ai/grok-4.1-fast
AI_PREMIUM_MONTHLY_CREDITS=1000
AI_PREMIUM_SAFE_AI_BUDGET_USD=0.70
AI_PREMIUM_CHAT_CREDITS=1
AI_PREMIUM_IMAGE_CREDITS=25
AI_PREMIUM_SEARCH_CREDITS=50
AI_PREMIUM_IMAGE_COOLDOWN_SECONDS=30
AI_PREMIUM_MAX_OUTPUT_TOKENS=900
AI_PREMIUM_DAILY_CREDIT_CAP=0
AI_PREMIUM_RPM=30
AI_GROK_INPUT_USD_PER_MILLION=0.20
AI_GROK_OUTPUT_USD_PER_MILLION=0.50
AI_GROK_SEARCH_TOOL_CALL_USD=0.005
AI_IMAGEN_FAST_USD_PER_IMAGE=0.02
AI_PREMIUM_REVENUE_USD_ESTIMATE=1.64

# Premium image provider (Vertex AI / Imagen 4 Fast)
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_ACCESS_TOKEN=
AI_PREMIUM_IMAGE_MODEL=imagen-4.0-fast-generate-001

# Token economy tuning
BOT_FREE_RESET_TOKENS=20
BOT_FREE_RESET_HOURS=12
BOT_PREMIUM_MONTHLY_TOKENS=1800
BOT_REFERRAL_INVITER_BONUS=40
BOT_REFERRAL_INVITEE_BONUS=20
BOT_AI_FREE_MIN_COST=8
BOT_AI_PREMIUM_MIN_COST=5
BOT_AI_FREE_COST_MULTIPLIER=4
BOT_AI_PREMIUM_COST_MULTIPLIER=2

# AI shared limits
AI_CREDIT_TOKEN_UNIT=1000
AI_CONTEXT_MESSAGES=12
# Set this to 0 if you want to keep only balances/counters and no per-user credit history
AI_TRANSACTION_LOG_LIMIT=0
# For reliable AI channel logging on hosting, set numeric channel id like -1001234567890
AI_LOG_CHANNEL_ID=-1001234567890
AI_LOG_CHANNEL_LINK=https://t.me/+0IXGNITrmlNmZGMy
AI_LOG_CHANNEL_STATE_PATH=

# Admin panel
ADMIN_USER_IDS=1392745444

# Neon/Postgres storage
# On Railway/render/redeploy environments, set DATABASE_URL or user data will reset with local files
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
NEON_DATABASE_URL=

# Optional translate fallback
LIBRETRANSLATE_ENDPOINT=
LIBRETRANSLATE_API_KEY=

# Optional common UA
HTTP_USER_AGENT=Mozilla/5.0 (XizmatlarBot/1.0; +https://core.telegram.org/bots/api)
