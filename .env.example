# Required
BOT_TOKEN=000000000:replace_with_real_token

# Optional Telegram Bot API server (self-hosted)
BOT_API_BASE=

# Paths
TEMP_DIR=downloads_tmp
LOG_FILE=logs/bot.log
LOCK_FILE=bot.lock

# Access control (comma-separated Telegram user IDs)
ALLOWED_USER_IDS=

# Limits
MAX_FILE_SIZE_MB=4096
CONCURRENT_DOWNLOADS=4
PER_USER_DOWNLOAD_LIMIT=1
DOWNLOAD_WORKERS=4
PARALLEL_DOWNLOAD_MIN_MB=64
MAX_URL_LENGTH=2048

# Download/Upload tuning
DOWNLOAD_CHUNK_KB=4096
UPLOAD_CHUNK_KB=2048
CONNECT_TIMEOUT_SECONDS=30
READ_TIMEOUT_SECONDS=120
UPLOAD_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2
SEND_MAX_RETRIES=4
SEND_RETRY_BACKOFF_SECONDS=3

# Behavior
PROGRESS_INTERVAL_SECONDS=4
SEND_PROGRESS_INTERVAL_SECONDS=3
PREFER_NATIVE_MEDIA=true
TELEGRAM_URL_SEND=true
NATIVE_MEDIA_MAX_MB=1024

# HTTP
HTTP_USER_AGENT=Mozilla/5.0 (DownloaderBot/3.0; +https://core.telegram.org/bots/api)
HTTP_CONNECTOR_LIMIT=300
HTTP_CONNECTOR_LIMIT_PER_HOST=100

# Runtime
POLLING_RESTART_DELAY_SECONDS=8
PROCESS_MONITOR_INTERVAL_SECONDS=30
CLEANUP_AFTER_HOURS=24
LOG_LEVEL=INFO

# YouTube
YOUTUBE_ENABLED=true
YOUTUBE_TIMEOUT_SECONDS=3600
YOUTUBE_MAX_DURATION_SECONDS=0
YOUTUBE_PREFER_MP4=true

# Optional API settings for extra services
ONESECMAIL_API_BASE=https://www.1secmail.com/api/v1/
TINYURL_API_TOKEN=
TINYURL_DOMAIN=tinyurl.com
DEEPLX_ENDPOINT=
DEEPLX_AUTH_KEY=
